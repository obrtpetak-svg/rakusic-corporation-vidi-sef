rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ══════════════════════════════════════════════════════════════
    // ROLE-BASED SECURITY RULES for Vi-Di-Sef (Enterprise Edition)
    // Uses authMapping collection: Firebase UID → { role, userId }
    // Roles: admin | leader | radnik (default)
    // ══════════════════════════════════════════════════════════════

    // ── Helper functions ─────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function getRole() {
      return get(/databases/$(database)/documents/authMapping/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuth() && getRole() == 'admin';
    }

    function hasMapping() {
      return isAuth() && exists(/databases/$(database)/documents/authMapping/$(request.auth.uid));
    }

    function adminOrNoMapping() {
      return isAuth() && (!hasMapping() || getRole() == 'admin');
    }

    // ── Input validation helpers ─────────────────────────────────
    function isString(field) {
      return request.resource.data[field] is string;
    }

    function isNumber(field) {
      return request.resource.data[field] is number;
    }

    function maxLen(field, max) {
      return request.resource.data[field].size() <= max;
    }

    function hasFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // ── AUTH MAPPING ─────────────────────────────────────────────
    match /authMapping/{uid} {
      allow read: if isAuth();
      allow write: if isAuth()
        && request.resource.data.keys().hasAll(['role', 'userId'])
        && request.resource.data.role in ['admin', 'leader', 'radnik']
        && request.resource.data.userId is string
        && request.resource.data.userId.size() <= 100;
    }

    // ═══════════════════════════════════════════════════════════════
    // ADMIN-ONLY WRITE collections (with input validation)
    // ═══════════════════════════════════════════════════════════════

    // ── Users ──
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if adminOrNoMapping()
        && hasFields(['username', 'name'])
        && isString('username') && maxLen('username', 50)
        && isString('name') && maxLen('name', 100);
      allow update: if adminOrNoMapping();
      allow delete: if adminOrNoMapping();
    }

    // ── Workers ──
    match /workers/{workerId} {
      allow read: if isAuth();
      allow create: if adminOrNoMapping()
        && hasFields(['name'])
        && isString('name') && maxLen('name', 100);
      allow update: if adminOrNoMapping();
      allow delete: if adminOrNoMapping();
    }

    // ── Projects ──
    match /projects/{projectId} {
      allow read: if isAuth();
      allow create: if adminOrNoMapping()
        && hasFields(['name'])
        && isString('name') && maxLen('name', 200);
      allow update: if adminOrNoMapping();
      allow delete: if adminOrNoMapping();
    }

    // ── Config ──
    match /config/{docId} {
      allow read: if isAuth();
      allow write: if adminOrNoMapping();
    }

    // ── Vehicles ──
    match /vehicles/{vehicleId} {
      allow read: if isAuth();
      allow create: if adminOrNoMapping()
        && hasFields(['name'])
        && isString('name') && maxLen('name', 100);
      allow update: if adminOrNoMapping();
      allow delete: if adminOrNoMapping();
    }

    // ── Smjestaj ──
    match /smjestaj/{smjestajId} {
      allow read: if isAuth();
      allow write: if adminOrNoMapping();
    }

    // ── Weather Rules ──
    match /weatherRules/{docId} {
      allow read: if isAuth();
      allow write: if adminOrNoMapping();
    }

    // ── Safety Templates ──
    match /safetyTemplates/{docId} {
      allow read: if isAuth();
      allow write: if adminOrNoMapping();
    }

    // ── GPS Settings ──
    match /gpsSettings/{docId} {
      allow read: if isAuth();
      allow write: if adminOrNoMapping();
    }
    match /gpsProjectSettings/{docId} {
      allow read: if isAuth();
      allow write: if adminOrNoMapping();
    }
    match /gpsWorkerSettings/{docId} {
      allow read: if isAuth();
      allow write: if adminOrNoMapping();
    }

    // ── Audit Log ──
    match /auditLog/{logId} {
      allow read: if adminOrNoMapping();
      allow create: if isAuth()
        && hasFields(['action', 'timestamp'])
        && isString('action') && maxLen('action', 200);
      allow update, delete: if false; // Audit logs are immutable
    }

    // ═══════════════════════════════════════════════════════════════
    // ALL-WRITE collections (with input validation)
    // ═══════════════════════════════════════════════════════════════

    // ── Timesheets ──
    match /timesheets/{timesheetId} {
      allow read: if isAuth();
      allow create: if isAuth()
        && hasFields(['date', 'workerId'])
        && isString('date') && maxLen('date', 10);
      allow update: if isAuth();
      allow delete: if adminOrNoMapping();
    }

    // ── Invoices ──
    match /invoices/{invoiceId} {
      allow read: if isAuth();
      allow create: if isAuth()
        && request.resource.data.keys().hasAny(['date', 'amount', 'number']);
      allow update: if isAuth();
      allow delete: if adminOrNoMapping();
    }

    // ── Otpremnice ──
    match /otpremnice/{otpremnicaId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if adminOrNoMapping();
    }

    // ── Production ──
    match /production/{productionId} {
      allow read: if isAuth();
      allow create: if isAuth()
        && hasFields(['name'])
        && isString('name') && maxLen('name', 200);
      allow update: if isAuth();
      allow delete: if adminOrNoMapping();
    }

    // ── Obaveze ──
    match /obaveze/{obavezaId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // ── Safety Checklists ──
    match /safetyChecklists/{docId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // ── Daily Logs ──
    match /dailyLogs/{docId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // ── Fuel Logs ──
    match /fuelLogs/{docId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // ── Leave Requests ──
    match /leaveRequests/{docId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // ── GPS Fleet Cache (Mapon integration) ──
    // Server writes via firebase-admin (bypasses rules)
    // Frontend reads via onSnapshot
    match /gps/{docId} {
      allow read: if isAuth();
      allow write: if adminOrNoMapping(); // manual admin overrides
    }
    match /gpsFleet/{docId} {
      allow read: if isAuth();
      allow write: if adminOrNoMapping();
    }
    match /gpsDedup/{docId} {
      allow read: if isAuth();
      allow write: if false; // only server writes
    }

    // ── GPS Live Data ──
    match /gpsLiveLocations/{docId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }
    match /gpsEvents/{docId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }
    match /gps-live/{docId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // ── Production Alerts ──
    match /prodAlerts/{docId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // ── Production Notifications ──
    match /prodNotifications/{docId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }
  }
}
